# Feishu 应用配置
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_TABLE_URL=
FEISHU_PROFILE_TABLE_URL=

# 激活码配置（首次使用需要配置）
ACTIVATION_TABLE_URL=
ACTIVATION_CODE=
ACTIVATION_MACHINE_ID=
ACTIVATION_STATUS=
ACTIVATION_EXPIRY=

# 自动回访配置
FOLLOWUP_ENABLED=0
FOLLOWUP_DRY_RUN=0
FOLLOWUP_POLL_INTERVAL=300
FOLLOWUP_BATCH_LIMIT=5
FOLLOWUP_VISIT_DELAY_DAYS=7
FOLLOWUP_CONSUME_DELAY_DAYS=10
FOLLOWUP_COOLDOWN_DAYS=7
FOLLOWUP_DAILY_CAP=50
FOLLOWUP_HOURLY_CAP=10
FOLLOWUP_QUIET_START_HOUR=22
FOLLOWUP_QUIET_END_HOUR=8
FOLLOWUP_PROMPT_VERSION=v1

# 回访字段映射（客户表）
FEISHU_FIELD_LAST_VISIT=最近到店时间
FEISHU_FIELD_LAST_CONSUME=最近消费时间
FEISHU_FIELD_CONSUME_SUMMARY=最近消费摘要
FEISHU_FIELD_FOLLOWUP_STATUS=回访状态
FEISHU_FIELD_FOLLOWUP_LAST_SENT_AT=回访发送时间
FEISHU_FIELD_FOLLOWUP_REASON=回访原因
FEISHU_FIELD_FOLLOWUP_SNAPSHOT=回访快照指纹
FEISHU_FIELD_FOLLOWUP_MESSAGE=回访消息
FEISHU_FIELD_FOLLOWUP_ATTEMPTS=回访尝试次数

# LLM 配置（OpenAI兼容）
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT=30
LLM_MAX_TOKENS=180
LLM_RETRY_COUNT=2

# WeChat RPA 配置
WECHAT_EXEC_PATH=
WELCOME_ENABLED=0
WELCOME_TEXT=
WELCOME_IMAGE_PATHS=

# 飞书轮询设置
FEISHU_RATE_LIMIT_COOLDOWN=0.3

# RPA 行为设置
RPA_DELAY_MIN=0.5
RPA_DELAY_MAX=1.5

# 日志与告警设置
LOG_RETENTION_DAYS=7
LOG_LEVEL=INFO
ALERT_COOLDOWN=60

# 超时设置
RELATIONSHIP_DETECT_TIMEOUT=6.0
PROFILE_WAIT_TIMEOUT=4.0
BUTTON_FIND_TIMEOUT=3.0

# 欢迎包细化设置
WELCOME_STEP_DELAY=1.0
WELCOME_RETRY_COUNT=0

# 聊天监控设置（可选）
MONITOR_KEYWORDS=
MAX_CHATS=6
